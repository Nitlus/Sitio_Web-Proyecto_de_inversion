# Local environment variables for development/testing
# WARNING: This file contains secrets. DO NOT commit to source control.
# Add `.env` to your .gitignore

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=TU_EMAIL
SMTP_PASS=YOUR_APP_PASSWORD_HERE
EMAIL_FROM=TU_EMAIL

# Toggle console fallback (1 = enabled). Set to 0 to prefer SMTP when configured.
ENABLE_CONSOLE_NOTIFICATIONS=0
# Simulation flag: if 1, emails are only logged (no SMTP attempt)
SIMULATE_EMAIL=0

# Optional tuning
EMAIL_RETRIES=3
EMAIL_BACKOFF=0.5